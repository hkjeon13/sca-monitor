APP_ENV=prod
SCA_MONITOR_HOST=0.0.0.0
SCA_MONITOR_PORT=18780
SCA_MONITOR_DATA_DIR=/data/psyche/Projects/sca-monitor/.data
SCA_MONITOR_DATABASE_URL=sqlite:////data/psyche/Projects/sca-monitor/.data/sca-monitor.sqlite3
# Optional split credentials for PostgreSQL. Leave SCA_MONITOR_DATABASE_URL unset to use these.
# API_DATABASE_URL=postgresql://sca_api:change-me@postgres:5432/sca_monitor
# WORKER_DATABASE_URL=postgresql://sca_worker:change-me@postgres:5432/sca_monitor
# Optional least-privilege runtime mode after deploy migration gate succeeds.
# SCA_MONITOR_AUTO_MIGRATE=false
# SCA_MONITOR_API_AUTO_MIGRATE=false
# SCA_MONITOR_WORKER_AUTO_MIGRATE=false
SCA_MONITOR_FRONTEND_DIR=/data/psyche/Projects/sca-monitor/frontend
SMOKE_TEST_TOKEN=change-me
SCA_MONITOR_POSTGRES_INTEGRATION_SMOKE=auto
SCA_MONITOR_SYSTEMD_MODE=validate
SCA_MONITOR_SYSTEMD_SCOPE=user
